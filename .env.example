# ============================================
# Weather API Keys (Backend Only)
# ============================================
# Weather API Keys - получить на:
# - WeatherAPI: https://www.weatherapi.com/signup.aspx
# - OpenWeather: https://openweathermap.org/api
# ============================================

# WeatherAPI.com (бесплатный план - 1M запросов/месяц)
WEATHERAPI_KEY=your_weatherapi_key_here

# OpenWeatherMap (бесплатный план - 60 запросов/минуту)
OPENWEATHER_API_KEY=your_openweather_key_here

# ============================================
# Server Configuration
# ============================================

# Прокси-сервер порт
PORT=8787

# Node environment (development | production | test)
NODE_ENV=development

# ============================================
# Optional: Healthcheck Configuration
# ============================================

# Enable upstream health checks (set to 1 to enable)
HEALTHCHECK_UPSTREAM=0

# Cache duration for health checks in milliseconds
HEALTHCHECK_CACHE_MS=5000

# ============================================
# Optional: Trust Proxy (for production behind reverse proxy)
# ============================================

# Set to 1 if behind a reverse proxy (nginx, apache, etc.)
TRUST_PROXY=0

# ============================================
# Instructions
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace 'your_*_key_here' with your actual API keys
# 3. Never commit .env to Git (it should be in .gitignore)
# 4. Keep this .env.example file up to date for other developers