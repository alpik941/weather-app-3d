# Backend proxy environment (server-side only)
# Copy to server/.env and set real keys.
WEATHERAPI_KEY=your_weatherapi_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here
PORT=8787

# Node environment
NODE_ENV=production

# Set to 1 only when running behind a trusted reverse proxy that sets X-Forwarded-For.
TRUST_PROXY=0

# If the SPA is hosted on a different origin than the proxy, set this to allow CORS.
# Example: ALLOWED_ORIGIN=https://your-frontend.example
ALLOWED_ORIGIN=

# Optional: enable upstream health probes (off by default)
HEALTHCHECK_UPSTREAM=0
